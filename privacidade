<title>Política de Privacidade — Gabriel Totino</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root { --bg:#FAFAF8; --bg2:#F4F2EE; --border:#E0DCD4; --text:#1A1A18; --muted:#6B6B60; --accent:#F05A28; --dark:#07080A; }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased}

  header{background:var(--dark);padding:20px 40px;display:flex;justify-content:space-between;align-items:center;border-bottom:3px solid var(--accent)}
  .logo{display:flex;align-items:center;gap:12px}
  .lm{width:36px;height:36px;position:relative;display:flex;align-items:center;justify-content:center}
  .lm::before,.lm::after,.lm .b,.lm .t{content:'';position:absolute;width:9px;height:9px}
  .lm::before{top:0;left:0;border-top:2px solid #E8E0D0;border-left:2px solid #E8E0D0}
  .lm::after{bottom:0;right:0;border-bottom:2px solid #E8E0D0;border-right:2px solid #E8E0D0}
  .lm .b{bottom:0;left:0;border-bottom:2px solid #E8E0D0;border-left:2px solid #E8E0D0}
  .lm .t{top:0;right:0;border-top:2px solid #E8E0D0;border-right:2px solid #E8E0D0}
  .lm span{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:900;color:var(--accent)}
  .logo-name{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;color:#E8E0D0;letter-spacing:3px}
  .back{font-size:13px;color:rgba(255,255,255,.5);text-decoration:none;transition:color .2s}
  .back:hover{color:var(--accent)}

  .hero{background:var(--dark);padding:60px 40px 48px;text-align:center;border-bottom:1px solid rgba(255,255,255,.06)}
  .hero-label{font-size:11px;color:var(--accent);letter-spacing:6px;text-transform:uppercase;display:block;margin-bottom:14px}
  .hero-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(36px,6vw,60px);font-weight:900;color:#E8E0D0;letter-spacing:2px;text-transform:uppercase;line-height:1}
  .hero-sub{font-size:13px;color:rgba(255,255,255,.4);margin-top:12px;letter-spacing:1px}

  .content{max-width:760px;margin:0 auto;padding:60px 40px 80px}

  h2{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--text);letter-spacing:2px;text-transform:uppercase;margin:40px 0 12px;padding-bottom:10px;border-bottom:2px solid var(--accent)}
  h2:first-of-type{margin-top:0}
  p{font-size:15px;color:var(--muted);line-height:1.85;font-weight:300;margin-bottom:14px}
  p strong{color:var(--text);font-weight:500}
  ul{margin:10px 0 14px 20px}
  li{font-size:15px;color:var(--muted);line-height:1.8;font-weight:300;margin-bottom:6px}
  a{color:var(--accent);text-decoration:none}
  a:hover{text-decoration:underline}

  .info-box{background:var(--bg2);border-left:3px solid var(--accent);padding:16px 20px;margin-bottom:14px;font-size:14px;color:var(--muted);line-height:1.7}
  .info-box strong{color:var(--text)}

  footer{background:var(--dark);border-top:1px solid rgba(255,255,255,.06);padding:24px 40px;text-align:center;font-size:11px;color:rgba(255,255,255,.3);letter-spacing:2px}

  @media(max-width:600px){header,footer{padding:16px 20px}.content{padding:40px 20px}.hero{padding:40px 20px 32px}}
</style>
</head>
